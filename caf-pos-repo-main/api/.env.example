# Cafe POS API — copy to .env and fill in real values.

# Database (asyncpg driver — required prefix)
DATABASE_URL=postgresql+asyncpg://postgres:pos@localhost:5432/cafe_pos

# Optional: separate DB used only by tests. Defaults to DATABASE_URL with `_test` appended.
# TEST_DATABASE_URL=postgresql+asyncpg://postgres:pos@localhost:5432/cafe_pos_test

# JWT — generate with: openssl rand -hex 32
JWT_SECRET=change-me-to-a-long-random-hex-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480
REFRESH_TOKEN_EXPIRE_MINUTES=43200

# Pusher (KDS realtime). Leave blank to no-op until you have creds.
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=ap1

# CORS — comma-separated origins. Use * only for local dev.
CORS_ORIGINS=http://localhost:3000

# Logging
LOG_LEVEL=INFO
ENVIRONMENT=local
