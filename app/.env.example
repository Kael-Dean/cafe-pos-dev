# ─── Database (Railway Postgres) ───
# Copy this file to .env and fill in real values. Never commit .env.
# Get DATABASE_URL from Railway dashboard → Postgres service → Connect → Postgres Connection URL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DBNAME?schema=public"

# ─── Auth.js (NextAuth v5) ───
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-32-byte-base64"
# In dev: leave blank (auto). In prod: full URL e.g. https://kafe.vercel.app
AUTH_URL=""

# ─── Pusher (KDS realtime) ───
# Sign up at pusher.com/channels → free tier. Leave blank for local-only mock.
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="ap1"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="ap1"

# ─── Cloudflare R2 (menu images) ───
# Phase 2 — leave blank for now. Local dev uses /public/uploads.
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET=""
R2_PUBLIC_URL=""

# ─── Application ───
NEXT_PUBLIC_APP_NAME="Kafé OS"
# Backend API (Railway)
NEXT_PUBLIC_API_BASE_URL="https://caf-pos-repo-production.up.railway.app"
NODE_ENV="development"

# ─── Default seed credentials (dev only) ───
# Used by prisma/seed.ts to create initial users. Override per-tenant in production.
SEED_TENANT_NAME="Kafé OS Demo"
SEED_TENANT_SLUG="demo"
SEED_STORE_NAME="Sukhumvit 49"
SEED_STORE_SLUG="suk49"
