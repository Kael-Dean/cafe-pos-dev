// Cafe POS — Prisma schema
// Provider: PostgreSQL (Railway)
// Multi-tenant: shared schema with storeId on every domain table

generator client {
  provider = "prisma-client-js"
}

// Connection URL is configured in prisma.config.ts (Prisma 7 pattern)
datasource db {
  provider = "postgresql"
}

// ============================================================
// Tenancy
// ============================================================

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  stores Store[]
  users  User[]
}

model Store {
  id          String   @id @default(cuid())
  tenantId    String
  tenant      Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name        String
  slug        String
  address     String?
  phone       String?
  // VAT (designed-for, disabled until registered — see DECISIONS.md D9)
  taxId       String?
  vatEnabled  Boolean  @default(false)
  vatRate     Decimal  @default(7.0) @db.Decimal(4, 2)
  // PromptPay
  promptpayId String? // mobile or tax id used to receive payments
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users          User[]
  categories     Category[]
  products       Product[]
  modifierGroups ModifierGroup[]
  inventoryItems InventoryItem[]
  orders         Order[]
  customers      Customer[]
  stockMovements StockMovement[]

  @@unique([tenantId, slug])
}

// ============================================================
// Identity & access
// ============================================================

enum Role {
  OWNER
  MANAGER
  BARISTA
  BAKER
}

model User {
  id        String   @id @default(cuid())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  storeId   String?
  store     Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)
  email     String?  @unique
  name      String
  // 4-6 digit PIN (bcrypt hash). Optional email login still possible for owner.
  pinHash   String
  role      Role     @default(BARISTA)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ordersCreated Order[]         @relation("OrderCreatedBy")
  voids         OrderVoidLog[]
  stockMoves    StockMovement[]

  @@index([tenantId, storeId])
}

// ============================================================
// Catalog
// ============================================================

model Category {
  id        String  @id @default(cuid())
  storeId   String
  store     Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name      String
  nameEn    String?
  icon      String?
  sortOrder Int     @default(0)
  isActive  Boolean @default(true)

  products Product[]

  @@unique([storeId, name])
  @@index([storeId, sortOrder])
}

model Product {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  categoryId  String
  category    Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  sku         String
  name        String
  nameEn      String?
  description String?
  basePrice   Decimal  @db.Decimal(10, 2)
  imageUrl    String?
  // visual hints from prototype (color tile, badge tag)
  colorHex    String?  @db.VarChar(9)
  badgeTag    String?  @db.VarChar(8)
  isActive    Boolean  @default(true)
  isFeatured  Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  modifierLinks ProductModifierGroup[]
  recipe        RecipeItem[]
  orderItems    OrderItem[]

  @@unique([storeId, sku])
  @@index([storeId, categoryId, isActive])
  @@index([storeId, isFeatured])
}

enum ModifierType {
  RADIO
  CHECKBOX
}

model ModifierGroup {
  id         String       @id @default(cuid())
  storeId    String
  store      Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name       String // "ขนาด", "นม", "ความหวาน", "เพิ่มเติม"
  type       ModifierType @default(RADIO)
  isRequired Boolean      @default(false)
  minSelect  Int          @default(0)
  maxSelect  Int          @default(1)
  sortOrder  Int          @default(0)

  modifiers    Modifier[]
  productLinks ProductModifierGroup[]

  @@index([storeId])
}

model Modifier {
  id              String         @id @default(cuid())
  groupId         String
  group           ModifierGroup  @relation(fields: [groupId], references: [id], onDelete: Cascade)
  name            String // "นมโอ๊ต", "L", "เพิ่มช็อต"
  priceDelta      Decimal        @default(0) @db.Decimal(10, 2)
  isDefault       Boolean        @default(false)
  // when this modifier consumes additional inventory (e.g., +1 shot of espresso)
  inventoryItemId String?
  inventoryItem   InventoryItem? @relation(fields: [inventoryItemId], references: [id], onDelete: SetNull)
  inventoryQty    Decimal?       @db.Decimal(10, 3)
  sortOrder       Int            @default(0)

  @@index([groupId])
}

// many-to-many: a product may use multiple modifier groups
model ProductModifierGroup {
  productId String
  groupId   String
  product   Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  group     ModifierGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  sortOrder Int           @default(0)

  @@id([productId, groupId])
}

// ============================================================
// Inventory & BOM
// ============================================================

model InventoryItem {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name        String
  unit        String // g, ml, ใบ, อัน, ชิ้น
  costPerUnit Decimal  @db.Decimal(10, 4) // 4 dp because cost can be tiny e.g. 0.0100
  stockOnHand Decimal  @db.Decimal(12, 3) // 3 dp for grams/ml
  parLevel    Decimal  @db.Decimal(12, 3)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  recipes   RecipeItem[]
  movements StockMovement[]
  modifiers Modifier[]

  @@unique([storeId, name])
  @@index([storeId, isActive])
}

model RecipeItem {
  id              String        @id @default(cuid())
  productId       String
  product         Product       @relation(fields: [productId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Restrict)
  quantity        Decimal       @db.Decimal(10, 3)

  @@unique([productId, inventoryItemId])
  @@index([productId])
}

enum MovementType {
  RECEIVE // รับเข้า (purchase)
  SALE // ตัดจากการขาย
  WASTE // ของเสีย
  ADJUST // ปรับสต็อก (audit)
  TRANSFER_IN // โอนเข้าจากสาขาอื่น
  TRANSFER_OUT // โอนออกไปสาขาอื่น
}

model StockMovement {
  id              String        @id @default(cuid())
  storeId         String
  store           Store         @relation(fields: [storeId], references: [id], onDelete: Cascade)
  inventoryItemId String
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  type            MovementType
  quantity        Decimal       @db.Decimal(12, 3) // positive value; sign inferred from type
  reason          String?
  refOrderId      String?
  refOrder        Order?        @relation(fields: [refOrderId], references: [id], onDelete: SetNull)
  createdById     String
  createdBy       User          @relation(fields: [createdById], references: [id], onDelete: Restrict)
  createdAt       DateTime      @default(now())

  @@index([storeId, createdAt])
  @@index([inventoryItemId, createdAt])
}

// ============================================================
// Customers / CRM
// ============================================================

enum CustomerTier {
  SILVER
  GOLD
  PLATINUM
}

model Customer {
  id          String       @id @default(cuid())
  storeId     String
  store       Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  phone       String // primary identifier
  name        String?
  email       String?
  birthday    DateTime?
  lineUserId  String? // for LINE OA integration (Phase 2)
  points      Int          @default(0)
  tier        CustomerTier @default(SILVER)
  totalSpend  Decimal      @default(0) @db.Decimal(12, 2)
  visitCount  Int          @default(0)
  lastVisitAt DateTime?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  orders Order[]

  @@unique([storeId, phone])
  @@index([storeId, lastVisitAt])
}

// ============================================================
// Orders
// ============================================================

enum OrderStatus {
  PENDING // เพิ่งสร้าง รอจ่ายเงิน
  PAID // ชำระแล้ว
  IN_PROGRESS // กำลังทำ
  READY // ทำเสร็จ พร้อมส่ง
  COMPLETED // ส่งให้ลูกค้าแล้ว
  VOID // ยกเลิก
}

enum Channel {
  DINE_IN
  TAKEAWAY
  DELIVERY
}

enum PaymentMethod {
  CASH
  CARD
  QR_PROMPTPAY
  LINE_PAY
  TRUEMONEY
  OTHER
}

model Order {
  id                  String         @id @default(cuid())
  storeId             String
  store               Store          @relation(fields: [storeId], references: [id], onDelete: Cascade)
  orderNumber         String // queue number shown to customer e.g. "A047"
  status              OrderStatus    @default(PENDING)
  channel             Channel        @default(DINE_IN)
  customerId          String?
  customer            Customer?      @relation(fields: [customerId], references: [id], onDelete: SetNull)
  // money
  subtotal            Decimal        @db.Decimal(12, 2)
  discount            Decimal        @default(0) @db.Decimal(12, 2)
  discountReason      String?
  tax                 Decimal        @default(0) @db.Decimal(12, 2)
  total               Decimal        @db.Decimal(12, 2)
  paidAmount          Decimal        @default(0) @db.Decimal(12, 2)
  paymentMethod       PaymentMethod?
  paymentRef          String? // EDC slip number, PromptPay txn ref
  paymentVerifiedById String?
  // idempotency to prevent duplicate orders from retries
  idempotencyKey      String?
  // audit
  createdById         String
  createdBy           User           @relation("OrderCreatedBy", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt           DateTime       @default(now())
  paidAt              DateTime?
  completedAt         DateTime?

  items      OrderItem[]
  voidLog    OrderVoidLog?
  stockMoves StockMovement[]

  @@unique([storeId, orderNumber])
  @@unique([storeId, idempotencyKey])
  @@index([storeId, createdAt])
  @@index([storeId, status])
  @@index([customerId])
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  order       Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId   String
  product     Product @relation(fields: [productId], references: [id], onDelete: Restrict)
  // snapshot fields — preserve historical accuracy even if product changes
  productName String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  // chosen modifiers as JSON: [{groupName, modifierName, priceDelta, inventoryItemId, inventoryQty}]
  modifiers   Json    @default("[]")
  notes       String?
  lineTotal   Decimal @db.Decimal(12, 2)

  @@index([orderId])
  @@index([productId])
}

model OrderVoidLog {
  id           String   @id @default(cuid())
  orderId      String   @unique
  order        Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reason       String
  approvedById String
  approvedBy   User     @relation(fields: [approvedById], references: [id], onDelete: Restrict)
  createdAt    DateTime @default(now())
}
